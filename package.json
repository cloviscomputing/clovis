{
  "name": "clovis",
  "version": "0.2.4",
  "description": "Local-first bookkeeping CLI, MCP server, and SQLite ledger engine",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cloviscomputing/clovis.git"
  },
  "bugs": {
    "url": "https://github.com/cloviscomputing/clovis/issues"
  },
  "homepage": "https://github.com/cloviscomputing/clovis#readme",
  "keywords": [
    "bookkeeping",
    "accounting",
    "sqlite",
    "ledger",
    "mcp"
  ],
  "engines": {
    "node": ">=26.3.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "clovis": "dist/cli/main.js",
    "clovis-mcp": "dist/mcp/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./app": {
      "types": "./dist/app/index.d.ts",
      "import": "./dist/app/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "RELEASING.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run build && vitest run --no-file-parallelism",
    "typecheck": "tsc --noEmit",
    "security:audit": "npm audit --audit-level=low",
    "prepack": "npm run build",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run release:check",
    "release:check": "node scripts/release-check.mjs",
    "release:status": "node scripts/release-status.mjs",
    "release:verify": "node scripts/release-verify.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^15.0.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "25.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
